font_family      CaskaydiaCove Nerd Font
bold_font        auto
italic_font      auto
bold_italic_font auto

font_size   14.0


scrollback_lines 1000
scrollback_pager_history_size 0

sync_to_monitor yes

background_opacity 0.8


# BEGIN_KITTY_THEME
# Everforest Dark Soft
include current-theme.conf
# END_KITTY_THEME